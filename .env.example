# ------------------------------------------------------------------
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local. Only .env.example belongs in git.
# ------------------------------------------------------------------

# Clerk (https://dashboard.clerk.com -> API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/chat
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/chat

# Supabase (https://supabase.com/dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# AI provider (OpenAI-compatible).
# For OpenRouter free models:
#   OPENAI_API_KEY   = your OpenRouter API key (sk-or-...)
#   OPENAI_BASE_URL  = https://openrouter.ai/api/v1
#   OPENAI_MODEL     = e.g. meta-llama/llama-4-maverick:free
# For OpenAI directly: leave OPENAI_BASE_URL empty.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
DAILY_MESSAGE_LIMIT=10
MAX_MESSAGE_LENGTH=8000
MAX_IMAGE_SIZE_MB=5
MAX_IMAGES_PER_MESSAGE=1
MAX_CONTEXT_MESSAGES=20
# NEXT_PUBLIC_ mirror used for client-side pre-validation only (server re-validates)
NEXT_PUBLIC_MAX_IMAGE_SIZE_MB=5
NEXT_PUBLIC_MAX_MESSAGE_LENGTH=8000
